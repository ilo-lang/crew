# crew configuration. Copy to .env and fill in.

# ---------- server (one instance, e.g. on Hetzner) ----------
CREW_PORT=7777
CREW_STORE=jsonl              # jsonl | sqlite | redis
DATA_DIR=./data

# Digest cron (server-side). cron expression for the digest job.
DIGEST_CRON="*/15 * * * *"
DIGEST_FEED_BATCH_MAX=500
DIGEST_MEMORY_DEBOUNCE_SEC=300
DIGEST_DRY_RUN=false

# Backup git repo target. Auth via GitHub App key on the server box.
BACKUP_REPO=
BACKUP_GH_APP_ID=
BACKUP_GH_APP_KEY_PATH=

# ---------- per-machine agent ----------
CREW_SERVER=https://crew.example.com
CREW_TOKEN=                   # machine bearer token
CREW_BIND=127.0.0.1:7676      # MCP HTTP endpoint
CREW_MACHINE=                 # defaults to hostname
CREW_CACHE=                   # defaults to ~/.crew
