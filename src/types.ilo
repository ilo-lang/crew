-- crew shared types
--
-- event:    one entry in the activity feed.
-- memory:   a slug-addressed note that future sessions read.
-- claim:    an exclusive hold on a target (ticket id, file path, etc).
-- artifact: a pointer to research/repro/benchmark output for a target.

type event{evid:t;ts:n;machine:t;agent:t;kind:t;target:t;note:t}

type memory{slug:t;body:t;updated:n}

type claim{target:t;holder:t;ts:n}

type artifact{target:t;kind:t;link:t;ts:n;machine:t;agent:t}
